# ═══════════════════════════════════════════════════════════
# NEXUS v6.0 — Environment Configuration
# Copy to .env and customize: cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── Ollama Cloud / Local ──────────────────────────────────
# URL of your Ollama instance (local or cloud)
OLLAMA_HOST=http://host.docker.internal:11434
# API key for Ollama Cloud (leave empty for local)
OLLAMA_API_KEY=

# ── Model Routing ─────────────────────────────────────────
# Fast: Quick responses, monitoring, background tasks
NEXUS_MODEL_FAST=glm-5.1:cloud
# Standard: Main agent work, coding, research
NEXUS_MODEL_STANDARD=kimi-k2.6:cloud
# Think: Complex reasoning, planning, analysis
NEXUS_MODEL_THINK=kimi-k2.6:cloud

# ── Fallback Models (auto-used if primary fails) ───────────
# These are defined in config.yaml but can be overridden here:
# NEXUS_FALLBACK_CLOUD=glm-5.1:cloud
# NEXUS_FALLBACK_LOCAL=qwen2.5:3b
# NEXUS_FALLBACK_ZAI=glm-4-plus

# ── Telegram Bot ──────────────────────────────────────────
# Get a token from @BotFather on Telegram
NEXUS_TG_TOKEN=
# Set to 1 to build with Telegram support
NEXUS_BUILD_TELEGRAM=0

# ── z.ai CLI (Vision/VLM) ────────────────────────────────
# For image analysis, OCR, screenshot capabilities
ZAI_API_KEY=

# ── Advanced ──────────────────────────────────────────────
# Auto-start on container boot
NEXUS_AUTO_START=0
# Debug mode (verbose logging)
NEXUS_DEBUG=0
# Max conversation budget (calls per conversation)
NEXUS_MAX_CALLS=200
# Max tokens per conversation
NEXUS_MAX_TOKENS=1000000